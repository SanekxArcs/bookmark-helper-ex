{
  "manifest_version": 3,
  "name": "Gemini Bookmark Manager",
  "version": "1.1.1",
  "description": "Intelligently categorize and sort bookmarks using Gemini AI",
  "permissions": ["bookmarks", "storage", "activeTab", "contextMenus"],
  "host_permissions": ["https://generativelanguage.googleapis.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
